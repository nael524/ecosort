{
  "name": "ecosort-ai",
  "productName": "EcoSort AI",
  "private": true,
  "version": "1.0.0",
  "description": "Smart Waste Detection System using YOLOv8",
  "author": "Natanael H. Sibagariang",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "desktop": "electron .",
    "electron": "electron .",
    "package": "electron-builder",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tensorflow-models/mobilenet": "^2.1.1",
    "@tensorflow/tfjs": "^4.22.0",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "swiper": "^14.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.ecosort.ai",
    "productName": "EcoSort AI",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "app.py",
      "index.py",
      "config.py",
      "ai/**/*",
      "api/**/*",
      "models/**/*",
      "ui/**/*",
      "captures/**/*",
      "reports/**/*",
      "logs/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models"
      },
      {
        "from": "ai",
        "to": "ai"
      },
      {
        "from": "api",
        "to": "api"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EcoSort AI"
    }
  }
}
